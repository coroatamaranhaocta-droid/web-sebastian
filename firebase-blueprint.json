{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the CRM.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role in the system." }
      },
      "required": ["uid", "email"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A customer or lead contact.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "status": { "type": "string", "enum": ["Lead", "Customer", "Inactive"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Deal": {
      "title": "Deal",
      "description": "A sales opportunity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "value": { "type": "number" },
        "stage": { "type": "string", "enum": ["Lead", "Qualified", "Proposal", "Negotiation", "Closed Won", "Closed Lost"] },
        "contactId": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "value", "stage", "ownerId"]
    },
    "Task": {
      "title": "Task",
      "description": "A task related to a contact or deal.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Todo", "In Progress", "Done"] },
        "contactId": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles." },
    "/contacts/{contactId}": { "schema": "Contact", "description": "Customer contacts." },
    "/deals/{dealId}": { "schema": "Deal", "description": "Sales deals." },
    "/tasks/{taskId}": { "schema": "Task", "description": "User tasks." }
  }
}
